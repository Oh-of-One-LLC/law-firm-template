---
import { Picture } from "astro:assets";
import heroImage from "../../../assets/architecture-hero.jpg";
---

<div class="md:flex md:h-[calc(100vh-5rem)] md:flex-col">
  <!-- Full-bleed image hero -->
  <section class="relative h-130 w-full overflow-hidden md:h-auto md:flex-1">
    <!-- Background image -->
    <Picture
      src={heroImage}
      formats={["avif", "webp"]}
      widths={[800, 1200, 1600]}
      sizes="100vw"
      alt="Modern architecture exterior"
      class="absolute inset-0 h-full w-full object-cover"
    />

    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-black/55" aria-hidden="true"></div>

    <!-- Text content -->
    <div
      class="relative mx-auto flex h-full max-w-5xl flex-col justify-center px-6 pb-18 md:px-8 md:pb-0"
    >
      <div class="flex max-w-lg flex-col gap-4 md:gap-5">
        <p class="text-accent text-xs font-semibold tracking-widest uppercase">
          Plan for a Secure Future
        </p>
        <h1
          class="text-3xl leading-tight font-bold tracking-tight text-white md:text-5xl"
        >
          Guiding Your Path to a Modern Architecture
        </h1>
        <p
          class="hidden text-sm leading-relaxed text-white/65 sm:block md:text-base"
        >
          At Oh of One Architecture, we seamlessly blend innovative design with
          functionality, creating spaces that inspire, elevate, and endure. From
          visionary concepts to flawless execution, we craft architectural
          masterpieces tailored to your lifestyle.
        </p>
        <div class="mt-1">
          <a
            href="/#call"
            class="bg-accent text-accent-fg inline-block rounded-md px-6 py-3 text-sm font-semibold transition hover:opacity-90 focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
          >
            Book a Call
          </a>
        </div>
      </div>
    </div>

    <!-- Stats box: full-width on mobile, anchored bottom-right on desktop -->
    <div
      class="bg-surface border-border divide-border absolute right-0 bottom-0 left-0 flex divide-x border-t md:right-0 md:left-auto md:w-auto md:border-l"
    >
      <div
        class="flex flex-1 flex-col gap-0.5 px-4 py-3 md:flex-none md:px-7 md:py-5"
      >
        <span class="text-accent text-lg font-bold md:text-2xl">+500K</span>
        <span class="text-text-muted text-xs">Happy User</span>
      </div>
      <div
        class="flex flex-1 flex-col gap-0.5 px-4 py-3 md:flex-none md:px-7 md:py-5"
      >
        <span class="text-accent text-lg font-bold md:text-2xl">+100K</span>
        <span class="text-text-muted text-xs">Our Partner</span>
      </div>
      <div
        class="flex flex-1 flex-col gap-0.5 px-4 py-3 md:flex-none md:px-7 md:py-5"
      >
        <span class="text-accent text-lg font-bold md:text-2xl">+1.4K</span>
        <span class="text-text-muted text-xs">Completed Projects</span>
      </div>
    </div>
  </section>

  <!-- Feature strip -->
  <div class="bg-surface border-border border-b">
    <div
      class="mx-auto grid max-w-5xl grid-cols-2 gap-8 px-8 py-10 md:grid-cols-4 md:py-6"
    >
      <!-- Expensive Living Spaces -->
      <div class="flex flex-col gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="text-text-muted h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 9.75L12 3l9 6.75V21a.75.75 0 01-.75.75H15v-4.5a.75.75 0 00-.75-.75h-4.5a.75.75 0 00-.75.75V21H3.75A.75.75 0 013 21V9.75z"
          ></path>
        </svg>
        <div>
          <p class="text-text text-sm font-semibold">Expensive Living Spaces</p>
          <p class="text-text-muted mt-1 text-xs leading-relaxed">
            Urban design draws together the many strands of place-making,
            environmental stewardship.
          </p>
        </div>
      </div>

      <!-- Smart Home Integration -->
      <div class="flex flex-col gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="text-text-muted h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
        <div>
          <p class="text-text text-sm font-semibold">Smart Home Integration</p>
          <p class="text-text-muted mt-1 text-xs leading-relaxed">
            Urban design draws together the many strands of place-making,
            environmental stewardship.
          </p>
        </div>
      </div>

      <!-- Home Security System -->
      <div class="flex flex-col gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="text-text-muted h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"
          ></path>
        </svg>
        <div>
          <p class="text-text text-sm font-semibold">Home Security System</p>
          <p class="text-text-muted mt-1 text-xs leading-relaxed">
            Urban design draws together the many strands of place-making,
            environmental stewardship.
          </p>
        </div>
      </div>

      <!-- Covered Parking -->
      <div class="flex flex-col gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="text-text-muted h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"
          ></path>
        </svg>
        <div>
          <p class="text-text text-sm font-semibold">Covered Parking</p>
          <p class="text-text-muted mt-1 text-xs leading-relaxed">
            Urban design draws together the many strands of place-making,
            environmental stewardship.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
