---
interface MenuItem {
  name: string;
  description: string;
  price: string;
}

interface MenuSection {
  title: string;
  items: MenuItem[];
}

interface Props {
  sections: MenuSection[];
}

const { sections } = Astro.props;
---

<section
  id="menu"
  aria-labelledby="menu-heading"
  class="bg-surface text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-14 flex flex-col gap-3">
      <p class="text-accent text-sm font-semibold tracking-widest uppercase">
        Our Menu
      </p>
      <h2
        id="menu-heading"
        class="text-4xl font-bold tracking-tight md:text-5xl"
      >
        Fresh from the fire
      </h2>
      <p class="text-text-muted mt-1 max-w-xl text-lg">
        Everything cooked in our 900° oak-fired oven. Simple ingredients,
        serious heat.
      </p>
    </div>

    <div class="grid gap-12 md:grid-cols-2">
      {
        sections.map((section) => (
          <div>
            <h3 class="border-border mb-6 border-b pb-3 text-xl font-semibold tracking-tight">
              {section.title}
            </h3>
            <ul class="flex flex-col gap-6" role="list">
              {section.items.map((item) => (
                <li class="flex items-start justify-between gap-4">
                  <div>
                    <p class="font-semibold">{item.name}</p>
                    <p class="text-text-muted mt-0.5 text-sm">
                      {item.description}
                    </p>
                  </div>
                  <span class="text-text-muted shrink-0 font-medium">
                    {item.price}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
