---
import { attorneys } from "./config";
---

<section
  id="attorneys"
  aria-labelledby="attorneys-heading"
  class="bg-brand relative w-full overflow-hidden px-8 py-24 md:py-32"
>
  <!-- Decorative overlays — not semantic or JS hooks -->
  <div
    class="atty-overlay-gradient pointer-events-none absolute inset-0"
    aria-hidden="true"
  >
  </div>
  <div
    class="atty-overlay-grid pointer-events-none absolute inset-0"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-5xl">
    <p
      class="text-accent mb-4 flex items-center gap-3 text-xs font-medium tracking-widest uppercase"
    >
      <span class="bg-accent inline-block h-px w-8"></span>
      The Team
    </p>
    <h2
      id="attorneys-heading"
      class="font-display text-brand-fg mb-16 text-4xl font-bold tracking-tight md:text-5xl"
    >
      Our <em class="text-accent">attorneys</em>
    </h2>

    <ul
      class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        attorneys.map((attorney) => (
          <li class="flex flex-col">
            <div class="atty-photo mb-6 rounded-sm" aria-hidden="true">
              <div class="flex h-full items-center justify-center">
                <span class="font-display text-brand-fg/20 text-[4rem] font-normal italic select-none">
                  {attorney.initials}
                </span>
              </div>
            </div>

            <h3 class="font-display text-brand-fg mb-1 text-xl font-semibold">
              {attorney.name}
            </h3>
            <p class="text-accent mb-4 text-xs font-medium tracking-widest uppercase">
              {attorney.title}
            </p>
            <p class="text-brand-fg/70 text-sm leading-relaxed font-light">
              {attorney.bio}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  /* atty-overlay-* and atty-photo are decoration targets only — not semantic or JS hooks */
  .atty-overlay-gradient {
    background-image:
      radial-gradient(
        ellipse at 80% 20%,
        color-mix(in srgb, var(--color-brand-subtle) 15%, transparent) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse at 20% 80%,
        color-mix(in srgb, var(--color-ac) 8%, transparent) 0%,
        transparent 50%
      );
  }

  .atty-overlay-grid {
    background-image:
      linear-gradient(
        color-mix(in srgb, var(--color-brand-fg) 3%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--color-brand-fg) 3%, transparent) 1px,
        transparent 1px
      );
    background-size: 60px 60px;
  }

  .atty-photo {
    aspect-ratio: 3/4;
    background: linear-gradient(
      160deg,
      var(--color-brand-subtle) 0%,
      var(--color-brand) 100%
    );
  }
</style>
