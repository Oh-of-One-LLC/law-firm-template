---
const attorneys = [
  {
    initials: "JM",
    name: "James Mercer",
    title: "Founding Partner",
    bio: "18 years advising Colorado businesses through formation, growth, and exit. Former in-house counsel at two Denver-based technology companies.",
  },
  {
    initials: "CA",
    name: "Claire Aldine",
    title: "Founding Partner",
    bio: "Specializes in M&A and commercial contracts. Previously with a top-10 national firm before co-founding Mercer & Aldine in 2008.",
  },
  {
    initials: "DP",
    name: "David Park",
    title: "Associate Attorney",
    bio: "Focuses on employment law and intellectual property. University of Colorado Law, 2018. Fluent in Korean and Mandarin.",
  },
];
---

<section
  id="attorneys"
  aria-labelledby="attorneys-heading"
  class="relative w-full overflow-hidden px-8 py-24 md:py-32"
  style="background: var(--color-brand);"
>
  <!-- Subtle decorative gradient -->
  <div
    class="pointer-events-none absolute -top-48 -right-48 h-[600px] w-[600px] rounded-full"
    style="background: radial-gradient(circle, rgba(90,140,106,0.15) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-5xl">
    <p
      class="mb-4 flex items-center gap-3 text-xs font-medium tracking-widest uppercase"
      style="color: var(--color-ac);"
    >
      <span class="inline-block h-px w-8" style="background: var(--color-ac);"></span>
      The Team
    </p>
    <h2
      id="attorneys-heading"
      class="mb-16 text-4xl font-bold tracking-tight md:text-5xl"
      style="font-family: var(--font-display); color: var(--color-brand-fg);"
    >
      Our <em style="font-style: italic; color: var(--color-ac);">attorneys</em>
    </h2>

    <ul class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3" role="list">
      {
        attorneys.map((attorney) => (
          <li class="flex flex-col">
            <!-- Photo placeholder -->
            <div
              class="mb-6 w-full overflow-hidden rounded-sm"
              style="aspect-ratio: 3/4; background: linear-gradient(160deg, var(--color-brand-subtle) 0%, var(--color-brand) 100%);"
              aria-hidden="true"
            >
              <div class="flex h-full items-center justify-center">
                <span
                  class="select-none"
                  style="font-family: var(--font-display); font-size: 4rem; font-weight: 400; font-style: italic; color: rgba(245,240,232,0.2);"
                >
                  {attorney.initials}
                </span>
              </div>
            </div>

            <p
              class="mb-1 text-xl font-semibold"
              style="font-family: var(--font-display); color: var(--color-brand-fg);"
            >
              {attorney.name}
            </p>
            <p
              class="mb-4 text-xs font-medium tracking-widest uppercase"
              style="color: var(--color-ac);"
            >
              {attorney.title}
            </p>
            <p
              class="text-sm leading-relaxed font-light"
              style="color: var(--color-brand-fg-muted);"
            >
              {attorney.bio}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
