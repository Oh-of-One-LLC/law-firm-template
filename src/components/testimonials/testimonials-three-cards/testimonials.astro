---
import { testimonials } from "./config";

const { heading, subtitle } = Astro.props;
---

<section
  id="testimonials"
  aria-labelledby="testimonials-heading"
  class="bg-surface text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-12 flex flex-col items-center gap-4 text-center md:mb-16">
      <p class="text-accent text-sm font-semibold tracking-widest uppercase">
        Testimonials
      </p>
      <h2
        id="testimonials-heading"
        class="max-w-2xl text-4xl font-bold tracking-tight md:text-5xl"
      >
        {heading}
      </h2>
      <p class="text-text-muted mx-auto max-w-xl text-lg">
        {subtitle}
      </p>
    </div>

    <ul
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        testimonials.map((t) => (
          <li>
            <blockquote class="bg-raised flex h-full flex-col gap-4 rounded-xl p-6">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="36"
                height="36"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="text-accent shrink-0"
                aria-hidden="true"
              >
                <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 0 1-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" />
              </svg>
              <p class="text-text-muted grow">{t.quote}</p>
              <footer>
                <cite class="not-italic">
                  <span class="text-text block font-semibold">{t.name}</span>
                  <span class="text-text-subtle text-sm">{t.context}</span>
                </cite>
              </footer>
            </blockquote>
          </li>
        ))
      }
    </ul>
  </div>
</section>
