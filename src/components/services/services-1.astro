---
const practices = [
  {
    number: "01",
    title: "Business Formation & Structure",
    description:
      "Entity selection, formation, operating agreements, shareholder agreements, and governance frameworks built to scale with your business.",
  },
  {
    number: "02",
    title: "Contracts & Commercial Agreements",
    description:
      "Drafting, review, and negotiation of commercial contracts — vendor agreements, service contracts, NDAs, and licensing arrangements.",
  },
  {
    number: "03",
    title: "Mergers & Acquisitions",
    description:
      "Buy-side and sell-side representation for acquisitions, mergers, and divestitures. Due diligence, deal structure, and closing support.",
  },
  {
    number: "04",
    title: "Employment Law",
    description:
      "Employment agreements, non-compete and non-solicitation provisions, HR policy development, and employer-side dispute resolution.",
  },
  {
    number: "05",
    title: "Intellectual Property",
    description:
      "Trademark registration and protection, IP assignment agreements, licensing, and trade secret protection strategies for growing companies.",
  },
  {
    number: "06",
    title: "Business Dispute Resolution",
    description:
      "Contract disputes, shareholder conflicts, and commercial litigation. We pursue resolution efficiently — in or out of court.",
  },
];
---

<section
  id="services"
  aria-labelledby="services-heading"
  class="bg-background text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 flex flex-col gap-4">
      <p class="text-text-muted flex items-center gap-3 text-xs font-medium tracking-widest uppercase">
        <span class="inline-block h-px w-8" style="background: var(--color-tx-muted);"></span>
        What We Do
      </p>
      <h2
        id="services-heading"
        class="text-4xl font-bold tracking-tight md:text-5xl"
        style="font-family: var(--font-display); color: var(--color-brand);"
      >
        Practice <em style="color: var(--color-tx-muted);">areas</em>
      </h2>
    </div>

    <ul
      class="grid grid-cols-1 gap-px sm:grid-cols-2 lg:grid-cols-3"
      role="list"
      style="background: var(--color-bg-surface);"
    >
      {
        practices.map((p) => (
          <li
            class="group relative overflow-hidden bg-background px-10 py-12 transition-colors duration-300 hover:bg-raised cursor-default"
          >
            <span
              class="absolute bottom-0 left-0 h-0.5 w-0 transition-all duration-400 group-hover:w-full"
              style="background: var(--color-brand);"
              aria-hidden="true"
            ></span>
            <p
              class="mb-6 text-5xl font-normal leading-none"
              style="font-family: var(--font-display); color: var(--color-bg-surface); font-style: italic;"
              aria-hidden="true"
            >
              {p.number}
            </p>
            <h3
              class="mb-4 text-xl font-semibold leading-snug"
              style="font-family: var(--font-display); color: var(--color-brand);"
            >
              {p.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed font-light">
              {p.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
