---
import { practices } from "./config";
---

<section
  id="services"
  aria-labelledby="services-heading"
  class="bg-surface text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-16 flex flex-col gap-4">
      <p
        class="text-text-muted flex items-center gap-3 text-xs font-medium tracking-widest uppercase"
      >
        <span class="bg-text-muted inline-block h-px w-8"></span>
        What We Do
      </p>
      <h2
        id="services-heading"
        class="font-display text-brand text-4xl font-bold tracking-tight md:text-5xl"
      >
        Practice <i class="text-text-muted italic">areas</i>
      </h2>
    </div>

    <ul
      class="bg-border grid grid-cols-1 gap-px sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        practices.map((p) => (
          <li class="group bg-background hover:bg-raised relative cursor-default overflow-hidden px-10 py-12 transition-colors duration-300">
            <span
              class="bg-brand absolute bottom-0 left-0 h-0.5 w-0 transition-all duration-400 group-hover:w-full"
              aria-hidden="true"
            />
            <span
              class="font-display text-accent mb-6 block text-5xl leading-none font-normal italic"
              aria-hidden="true"
            >
              {p.number}
            </span>
            <h3 class="font-display text-brand mb-4 text-xl leading-snug font-semibold">
              {p.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed font-light">
              {p.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
