---
import type { ImageMetadata } from "astro";

interface MenuItem {
  name: string;
  href: string;
  cta?: boolean;
}

interface Props {
  logo: string | ImageMetadata;
  menuItems: MenuItem[];
}

const { menuItems, logo } = Astro.props;
---

<header
  class="bg-brand text-brand-fg sticky top-0 z-50 border-b border-black/20"
>
  <div
    class="mx-auto flex h-20 max-w-6xl items-center justify-between px-8 lg:px-12"
  >
    <a
      href="/#top"
      class="focus:ring-offset-brand text-lg font-semibold tracking-wide transition-all focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none lg:text-xl"
      style="font-family: var(--font-display); color: var(--color-brand-fg);"
    >
      {
        typeof logo === "string" && logo.includes(" & ") ? (
          <>
            {logo.split(" & ")[0]}
            <span style="color: var(--color-ac);"> &amp; </span>
            {logo.split(" & ")[1]}
          </>
        ) : (
          logo
        )
      }
    </a>
    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-8 text-base font-medium md:flex">
      {
        (menuItems ?? []).map((item) =>
          item.cta ? (
            <a
              href={item.href}
              class="focus:ring-offset-brand rounded-sm px-5 py-2 text-sm font-medium tracking-wide uppercase transition-all hover:opacity-90 focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
              style="background: var(--color-ac); color: #fff; letter-spacing: 0.06em;"
            >
              {item.name}
            </a>
          ) : (
            <a
              href={item.href}
              class="focus:ring-offset-brand text-sm tracking-widest uppercase opacity-80 transition-all hover:opacity-100 focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
            >
              {item.name}
            </a>
          ),
        )
      }
    </nav>

    <!-- Mobile Button -->
    <button
      id="menu-btn"
      class="focus:ring-offset-brand rounded-lg p-4 text-3xl transition hover:bg-slate-100 focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none md:hidden"
      aria-label="Toggle Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      ☰
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="bg-brand absolute max-h-0 w-full overflow-hidden transition-all duration-300 md:hidden"
  >
    <nav class="flex flex-col gap-4 pb-5 text-base font-medium">
      {
        (menuItems ?? []).map((item) => (
          <a
            href={item.href}
            class="focus:ring-offset-brand mx-8 text-lg focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
          >
            {item.name}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.style.maxHeight;

    if (isOpen) {
      menu!.style.maxHeight = "";
      btn.setAttribute("aria-expanded", "false");
    } else {
      menu!.style.maxHeight = menu!.scrollHeight + "px";
      btn.setAttribute("aria-expanded", "true");
    }
  });

  menu!.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu!.style.maxHeight = "";
      btn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
