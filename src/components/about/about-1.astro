---

---

<section
  id="about"
  aria-labelledby="about-heading"
  class="bg-surface text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col gap-12 md:flex-row md:items-center md:gap-16">
      <div class="flex flex-col gap-6 md:flex-1">
        <p class="text-accent flex items-center gap-3 text-xs font-medium tracking-widest uppercase">
          <span class="bg-accent inline-block h-px w-8"></span>
          Denver Business Law
        </p>
        <h2
          id="about-heading"
          class="text-4xl font-bold tracking-tight md:text-5xl"
          style="font-family: var(--font-display);"
        >
          About Mercer <span style="color: var(--color-ac);">&amp;</span> Aldine
        </h2>
        <p class="text-text-muted text-lg leading-relaxed font-light">
          Founded in 2008, Mercer &amp; Aldine has built a reputation for
          direct, no-nonsense legal counsel for Colorado businesses. We advise
          companies at every stage — from formation through acquisition and
          beyond.
        </p>
        <p class="text-text-muted text-lg leading-relaxed font-light">
          Our attorneys bring deep transactional experience and straightforward
          communication. No billable-hour surprises. No bureaucracy.
        </p>
        <a
          href="/#call"
          class="focus:ring-offset-surface mt-2 inline-flex w-fit rounded-sm px-8 py-3 text-sm font-medium uppercase tracking-widest text-white transition hover:opacity-90 focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
          style="background: var(--color-brand); letter-spacing: 0.08em;"
        >
          Schedule a Consultation
        </a>
      </div>

      <dl
        class="grid grid-cols-2 gap-4 md:flex-1"
        aria-label="Firm highlights"
      >
        <div class="border-border flex flex-col gap-1 rounded-sm border p-6">
          <dt class="text-text-muted text-sm">Years serving Denver</dt>
          <dd
            class="text-4xl font-bold"
            style="font-family: var(--font-display); color: var(--color-ac);"
          >18+</dd>
        </div>
        <div class="border-border flex flex-col gap-1 rounded-sm border p-6">
          <dt class="text-text-muted text-sm">Transactions closed</dt>
          <dd
            class="text-4xl font-bold"
            style="font-family: var(--font-display); color: var(--color-ac);"
          >400+</dd>
        </div>
        <div class="border-border flex flex-col gap-1 rounded-sm border p-6">
          <dt class="text-text-muted text-sm">Client retention rate</dt>
          <dd
            class="text-4xl font-bold"
            style="font-family: var(--font-display); color: var(--color-ac);"
          >96%</dd>
        </div>
        <div class="border-border flex flex-col gap-1 rounded-sm border p-6">
          <dt class="text-text-muted text-sm">Colorado licensed</dt>
          <dd
            class="text-4xl font-bold"
            style="font-family: var(--font-display); color: var(--color-ac);"
          >100%</dd>
        </div>
      </dl>
    </div>
  </div>
</section>
