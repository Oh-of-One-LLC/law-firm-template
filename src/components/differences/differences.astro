---
import { rows } from "./config";
---

<section
  id="differences"
  aria-labelledby="differences-heading"
  class="bg-brand-subtle w-full scroll-mt-28 px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <h2
      id="differences-heading"
      class="text-brand-fg pb-4 text-center text-4xl font-bold tracking-tight md:text-6xl"
    >
      What Sets Me Apart
    </h2>
    <p class="text-brand-fg-muted pb-12 text-center text-xl md:text-2xl">
      Not all web developers are equal. Here's how I stack up.
    </p>

    <div class="mt-12 overflow-x-auto rounded-lg">
      <table class="w-full border-collapse text-left text-sm md:text-base">
        <caption class="sr-only">
          Feature comparison: Oh of One vs. typical web agencies
        </caption>
        <thead>
          <tr>
            <th
              scope="col"
              class="text-brand-fg-muted w-1/2 py-6 pr-8 text-sm font-semibold tracking-wide uppercase"
            >
              Feature
            </th>
            <th scope="col" class="relative w-1/4 px-8 py-6 text-center">
              <div
                class="bg-brand-fg absolute inset-x-0 top-0 h-4 rounded-t-sm"
              >
              </div>
              <span class="text-brand-fg text-base font-bold md:text-lg"
                >ME</span
              >
            </th>
            <th
              scope="col"
              class="text-brand-fg-muted w-1/4 py-6 pl-2 text-center text-sm font-semibold tracking-wide uppercase"
            >
              Others
            </th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row) => (
              <tr class="border-t border-white/10">
                <th scope="row" class="text-brand-fg py-6 pr-8 font-medium">
                  {row.feature}
                </th>
                <td class="bg-brand-accent/5 px-8 py-6 text-center">
                  {row.ours ? (
                    <>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="text-brand-accent inline-block size-5"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      <span class="sr-only">Yes</span>
                    </>
                  ) : (
                    <>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="inline-block size-5 text-red-400"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      <span class="sr-only">No</span>
                    </>
                  )}
                </td>
                <td class="py-6 pl-2 text-center">
                  {row.theirs ? (
                    <>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="text-brand-accent inline-block size-5"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      <span class="sr-only">Yes</span>
                    </>
                  ) : (
                    <>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="inline-block size-5 text-red-400"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      <span class="sr-only">No</span>
                    </>
                  )}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-12 text-center">
      <a
        href="/#contact"
        class="bg-accent text-accent-fg hover:bg-accent-hover focus:ring-accent focus:ring-offset-surface inline-flex rounded-lg px-8 py-3 font-semibold transition focus:ring-2 focus:ring-offset-1 focus:outline-none"
      >
        Work With Me
      </a>
    </div>
  </div>
</section>
