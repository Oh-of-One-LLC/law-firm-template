---
import "../styles/global.css";
import Header from "../components/header.astro";
import Footer from "../components/footer/footer-with-form.astro";
import dmSans from "../assets/dm-sans.woff2";
import dmSansItalic from "../assets/dm-sans-italic.woff2";
import playfairDisplay from "../assets/playfair-display.woff2";
import playfairDisplayItalic from "../assets/playfair-display-italic.woff2";
import { COMPANY_NAME as companyName, PHONE as phone } from "../config";

const menuItems = [
  { name: "Practice Areas", href: "/#services" },
  { name: "Attorneys", href: "/#attorneys" },
  { name: "Clients", href: "/#testimonials" },
  { name: "Free Consultation", href: "/#call", cta: true },
];

const logo = "Mercer & Aldine";

const { pageTitle = "Mercer & Aldine | Business Law | Denver, CO" } =
  Astro.props;
---

<!doctype html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta
      name="description"
      content="Mercer & Aldine advises Denver businesses through their most critical legal decisions — from formation and contracts to M&A and dispute resolution."
    />
    <meta name="theme-color" content="#2C4A35" />
    <link rel="preload" href={dmSans} as="font" type="font/woff2" crossorigin />
    <link
      rel="preload"
      href={dmSansItalic}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={playfairDisplay}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={playfairDisplayItalic}
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>

  <body
    class="bg-background text-text min-h-full antialiased"
    style="font-family: var(--font-sans)"
  >
    <div class="flex min-h-screen flex-col" id="top">
      <Header logo={logo} menuItems={menuItems} />

      <main class="flex-1" role="main">
        <slot name="main" />
      </main>

      <Footer companyName={companyName} phone={phone} />
    </div>
  </body>
</html>
